@page "/results/{Id}"
@inject ResultsRepository Repo
@inject NavigationManager Nav
@inject ExportService ExportSvc
@inject IJSRuntime JS

<PageTitle>@(_entry?.IsFailed == true ? "Failed Extraction" : _entry?.Output.Meta.DocumentType ?? "Result") — OmniExtract</PageTitle>

@if (_entry is null)
{
    <header class="topbar"><span class="topbar-title">Result</span></header>
    <div class="page-content"><div class="empty"><div class="empty-title">Result not found.</div></div></div>
}
else if (_entry.IsFailed)
{
    <header class="topbar">
        <span class="topbar-title">Result Detail</span>
        <span class="topbar-sep">/</span>
        <span class="topbar-sub" style="color:var(--error)">Extraction Failed</span>
        <div class="topbar-right">
            <button class="btn btn-ghost btn-sm" @onclick='() => Nav.NavigateTo("/results")'>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15,18 9,12 15,6"/></svg>
                All Results
            </button>
        </div>
    </header>

    <div class="page-content afu">
        <div class="detail-hero" style="background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.2);">
            <div class="detail-hero-body">
                <div class="detail-doc-icon" style="color:var(--error);">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </div>
                <div style="flex:1;min-width:0;">
                    <div class="detail-doc-type" style="color:var(--error);">Extraction Failed</div>
                    <div class="detail-doc-name">@_entry.FileName</div>
                    <div class="detail-meta-row">
                        <span class="detail-meta-item">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
                            @_entry.ProcessedAt.ToString("d MMM yyyy, HH:mm")
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div style="margin-top:24px;background:rgba(248,113,113,.06);border:1px solid rgba(248,113,113,.2);border-radius:10px;padding:20px 24px;">
            <div style="font-size:13px;font-weight:600;color:var(--error);margin-bottom:8px;">Error</div>
            <div style="font-size:14px;color:var(--text-100);">@_entry.ErrorMessage</div>
        </div>

        @if (_entry.ErrorDetail is not null)
        {
            <div style="margin-top:16px;">
                <button class="section-toggle" @onclick='() => Toggle("errdetail")'>
                    <span class="section-chevron">@(IsOpen("errdetail") ? "▾" : "▶")</span>
                    <span class="section-toggle-title">Stack Trace</span>
                </button>
                @if (IsOpen("errdetail"))
                {
                    <pre style="margin-top:8px;font-size:11px;background:rgba(0,0,0,.35);color:var(--error);padding:16px;border-radius:6px;overflow-x:auto;white-space:pre-wrap;word-break:break-all;" class="afi">@_entry.ErrorDetail</pre>
                }
            </div>
        }

        <div style="margin-top:32px;">
            <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/upload")'>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16,16 12,12 8,16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
                Re-upload
            </button>
        </div>
    </div>
}
else
{
    var m = _entry.Output.Meta;
    var conf = m.Confidence * 100;
    var circumference = 2 * Math.PI * 44;
    var dashArray = $"{conf / 100 * circumference:F1} {circumference:F1}";

    <header class="topbar">
        <span class="topbar-title">Result Detail</span>
        <span class="topbar-sep">/</span>
        <span class="topbar-sub">@m.DocumentType</span>
        <div class="topbar-right">
            <button class="btn btn-ghost btn-sm" @onclick="DownloadJson">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7,10 12,15 17,10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                JSON
            </button>
            <button class="btn btn-ghost btn-sm" @onclick="DownloadCsv">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7,10 12,15 17,10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                CSV
            </button>
            <button class="btn btn-ghost btn-sm" @onclick='() => Nav.NavigateTo("/results")'>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15,18 9,12 15,6"/></svg>
                All Results
            </button>
        </div>
    </header>

    <div class="page-content afu">

        <!-- Hero header -->
        <div class="detail-hero">
            <div class="detail-hero-body">
                <div class="detail-doc-icon">
                    @((MarkupString)DomainIconLarge(_entry.Output.Categories.Domain))
                </div>
                <div style="flex:1;min-width:0;">
                    <div class="detail-doc-type">@_entry.Output.Categories.Domain &nbsp;·&nbsp; @_entry.Output.Categories.Subdomain</div>
                    <div class="detail-doc-name">@m.DocumentType</div>
                    <div class="detail-meta-row">
                        <span class="detail-meta-item">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/></svg>
                            @if (_entry.OriginalFileUrl is not null)
                            {
                                <a href="@_entry.OriginalFileUrl" target="_blank" style="color:inherit;text-decoration:underline;text-underline-offset:3px;">@_entry.FileName</a>
                            }
                            else
                            {
                                @_entry.FileName
                            }
                        </span>
                        <span class="detail-meta-item">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
                            @_entry.ProcessedAt.ToString("d MMM yyyy, HH:mm")
                        </span>
                        @if (m.Language.Any())
                        {
                            <span class="detail-meta-item">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                                @string.Join(", ", m.Language).ToUpper()
                            </span>
                        }
                        <span class="badge @_entry.Output.Categories.Sensitivity" style="font-size:12px;">
                            <div class="badge-dot"></div>
                            @_entry.Output.Categories.Sensitivity
                        </span>
                        <span class="badge method-badge">@m.ExtractionMethod</span>
                    </div>
                </div>

                <!-- Confidence ring -->
                <div class="ring-wrap" style="width:110px;height:110px;flex-shrink:0;">
                    <svg width="110" height="110" viewBox="0 0 110 110">
                        <circle cx="55" cy="55" r="44" fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="8"/>
                        <circle cx="55" cy="55" r="44" fill="none"
                                stroke="@(conf >= 90 ? "#4ade80" : conf >= 75 ? "#fbbf24" : "#f87171")"
                                stroke-width="8"
                                stroke-linecap="round"
                                stroke-dasharray="@dashArray"
                                transform="rotate(-90 55 55)"
                                style="transition:stroke-dasharray 1s var(--ease)"/>
                    </svg>
                    <div class="ring-label">
                        <div class="ring-pct" style="color:#fff">@conf.ToString("F0")%</div>
                        <div class="ring-sub" style="color:rgba(255,255,255,.5)">Confidence</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Warnings -->
        @if (m.Warnings.Any())
        {
            <div class="warn-list" style="margin-bottom:24px;">
                @foreach (var w in m.Warnings)
                {
                    <div class="warn-item">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:1px;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                        @w
                    </div>
                }
            </div>
        }

        <!-- Main layout -->
        <div class="detail-cols">

            <!-- Main column -->
            <div style="display:flex;flex-direction:column;gap:24px;">

                @{
                    var hasDeepAnalysis = _entry.Output.Data.ContainsKey("distilled_findings");
                    var hasNarrative    = !hasDeepAnalysis && _entry.Output.Data.ContainsKey("sections");
                }

                @if (hasDeepAnalysis)
                {
                    <!-- Deep Analysis layout -->
                    @if (_entry.Output.Data.TryGetValue("one_page_summary", out var summaryObj) && summaryObj is not null)
                    {
                        <div class="da-summary-panel">
                            <div class="da-panel-label">One-Page Summary</div>
                            <p class="da-summary-text">@summaryObj.ToString()</p>
                        </div>
                    }

                    @if (_entry.Output.Data.TryGetValue("distilled_findings", out var findingsObj) && findingsObj is not null)
                    {
                        <div>
                            <button class="section-toggle" @onclick='() => Toggle("findings")'>
                                <span class="section-chevron">@(IsOpen("findings") ? "▾" : "▶")</span>
                                <span class="section-toggle-title">Key Findings</span>
                            </button>
                            @if (IsOpen("findings"))
                            {
                                <div class="da-findings-list">
                                    @foreach (var item in ParseJsonArray(findingsObj.ToString()))
                                    {
                                        var finding = item.TryGetValue("finding", out var f) ? f : "";
                                        var certainty = item.TryGetValue("certainty", out var c) ? c : "medium";
                                        var src = item.TryGetValue("source_section", out var s) ? s : null;
                                        <div class="da-finding">
                                            <span class="da-certainty da-certainty-@certainty">@certainty</span>
                                            <div class="da-finding-body">
                                                <p>@finding</p>
                                                @if (!string.IsNullOrEmpty(src))
                                                {
                                                    <span class="da-source">@src</span>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }

                    @if (_entry.Output.Data.TryGetValue("risks", out var risksObj) && risksObj is not null)
                    {
                        <div>
                            <button class="section-toggle" @onclick='() => Toggle("risks")'>
                                <span class="section-chevron">@(IsOpen("risks") ? "▾" : "▶")</span>
                                <span class="section-toggle-title">Risks</span>
                            </button>
                            @if (IsOpen("risks"))
                            {
                                <ul class="da-list da-list-risk">
                                    @foreach (var risk in ParseJsonStringArray(risksObj.ToString()))
                                    {
                                        <li>@risk</li>
                                    }
                                </ul>
                            }
                        </div>
                    }

                    @if (_entry.Output.Data.TryGetValue("key_facts", out var factsObj) && factsObj is not null)
                    {
                        <div>
                            <button class="section-toggle" @onclick='() => Toggle("keyfacts")'>
                                <span class="section-chevron">@(IsOpen("keyfacts") ? "▾" : "▶")</span>
                                <span class="section-toggle-title">Key Facts</span>
                            </button>
                            @if (IsOpen("keyfacts"))
                            {
                                <ul class="da-list da-list-fact">
                                    @foreach (var fact in ParseJsonStringArray(factsObj.ToString()))
                                    {
                                        <li>@fact</li>
                                    }
                                </ul>
                            }
                        </div>
                    }

                    @if (_entry.Output.Data.TryGetValue("flags", out var flagsObj) && flagsObj is not null)
                    {
                        var flags = ParseJsonStringArray(flagsObj.ToString());
                        @if (flags.Any())
                        {
                            <div>
                                <button class="section-toggle" @onclick='() => Toggle("flags")'>
                                    <span class="section-chevron">@(IsOpen("flags") ? "▾" : "▶")</span>
                                    <span class="section-toggle-title">Flags</span>
                                </button>
                                @if (IsOpen("flags"))
                                {
                                    <ul class="da-list da-list-flag">
                                        @foreach (var flag in flags)
                                        {
                                            <li>@flag</li>
                                        }
                                    </ul>
                                }
                            </div>
                        }
                    }
                }
                else if (hasNarrative)
                {
                    <!-- Narrative layout -->
                    @if (_entry.Output.Data.TryGetValue("summary", out var narSummaryObj) && narSummaryObj is not null)
                    {
                        <div class="narr-summary-panel">
                            <div class="narr-panel-label">Summary</div>
                            <p class="narr-summary-text">@narSummaryObj.ToString()</p>
                        </div>
                    }

                    @if (_entry.Output.Data.TryGetValue("sections", out var sectionsObj) && sectionsObj is not null)
                    {
                        <div>
                            <button class="section-toggle" @onclick='() => Toggle("sections")'>
                                <span class="section-chevron">@(IsOpen("sections") ? "▾" : "▶")</span>
                                <span class="section-toggle-title">Sections</span>
                            </button>
                            @if (IsOpen("sections"))
                            {
                                <div class="narr-sections">
                                    @foreach (var sec in ParseJsonArray(sectionsObj.ToString()))
                                    {
                                        var heading = sec.TryGetValue("heading", out var h) ? h : "(untitled)";
                                        var secSummary = sec.TryGetValue("summary", out var ss) ? ss : null;
                                        var keyPoints = sec.TryGetValue("key_points", out var kp) ? ParseJsonStringArray(kp) : [];
                                        <div class="narr-section">
                                            <div class="narr-section-heading">@heading</div>
                                            @if (!string.IsNullOrEmpty(secSummary))
                                            {
                                                <p class="narr-section-summary">@secSummary</p>
                                            }
                                            @if (keyPoints.Any())
                                            {
                                                <ul class="narr-key-points">
                                                    @foreach (var pt in keyPoints)
                                                    {
                                                        <li>@pt</li>
                                                    }
                                                </ul>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }

                    @if (_entry.Output.Data.TryGetValue("conclusions", out var conclusionsObj) && conclusionsObj is not null)
                    {
                        <div>
                            <button class="section-toggle" @onclick='() => Toggle("conclusions")'>
                                <span class="section-chevron">@(IsOpen("conclusions") ? "▾" : "▶")</span>
                                <span class="section-toggle-title">Conclusions</span>
                            </button>
                            @if (IsOpen("conclusions"))
                            {
                                <div class="narr-conclusions">@conclusionsObj.ToString()</div>
                            }
                        </div>
                    }
                }
                else
                {
                <!-- Extracted fields (standard structured layout) -->
                @if (_entry.Output.Data.Any())
                {
                    var fieldsOpen = IsOpen("fields");
                    <div>
                        <button class="section-toggle" @onclick='() => Toggle("fields")'>
                            <span class="section-chevron">@(fieldsOpen ? "▾" : "▶")</span>
                            <span class="section-toggle-title">Extracted Fields</span>
                            <span class="section-toggle-meta">@_entry.Output.Data.Count fields</span>
                        </button>
                        @if (fieldsOpen)
                        {
                            <div class="fields-grid">
                                @foreach (var (k, v) in _entry.Output.Data)
                                {
                                    <div class="field-cell">
                                        <div class="field-key">@k.Replace("_", " ")</div>
                                        <div class="field-val">@(v?.ToString() ?? "—")</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
                }

                <!-- Tables -->
                @for (var ti = 0; ti < _entry.Output.Tables.Count; ti++)
                {
                    var table = _entry.Output.Tables[ti];
                    if (table.Count < 2) continue;
                    var tableKey = $"table_{ti}";
                    var tableOpen = IsOpen(tableKey);
                    var tableIndex = ti;
                    <div>
                        <button class="section-toggle" @onclick='() => Toggle(tableKey)'>
                            <span class="section-chevron">@(tableOpen ? "▾" : "▶")</span>
                            <span class="section-toggle-title">Table @(tableIndex + 1)</span>
                            <span class="section-toggle-meta">@(table.Count - 1) rows · @table[0].Count cols</span>
                        </button>
                        @if (tableOpen)
                        {
                            <div class="table-wrap">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            @foreach (var h in table[0])
                                            {
                                                <th>@h</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (var ri = 1; ri < table.Count; ri++)
                                        {
                                            <tr>
                                                @foreach (var cell in table[ri])
                                                {
                                                    <td>@cell</td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                }

                <!-- Raw JSON -->
                <div>
                    <button class="section-toggle" @onclick='() => Toggle("raw")'>
                        <span class="section-chevron">@(IsOpen("raw") ? "▾" : "▶")</span>
                        <span class="section-toggle-title">Raw JSON Output</span>
                    </button>
                    @if (IsOpen("raw"))
                    {
                        <pre class="raw-json afi">@_json</pre>
                    }
                </div>

            </div>

            <!-- Sidebar -->
            <div class="detail-sidebar">

                <!-- Agent Recommendation -->
                @if (_entry.Output.Data.TryGetValue("agent_recommendation", out var recObj) && recObj is not null)
                {
                    var rec = ParseJsonObjectFlat(recObj.ToString());
                    var agentName = rec.TryGetValue("recommended_agent", out var an) ? an : null;
                    var recDomain = rec.TryGetValue("domain", out var rd) ? rd : null;
                    var recConf = rec.TryGetValue("confidence", out var rc) && double.TryParse(rc, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var rcv) ? (double?)rcv : null;
                    var reasoning = rec.TryGetValue("reasoning", out var rr) ? rr : null;
                    var signalsRaw = recObj?.ToString() is string recJson ? ParseJsonStringArrayFromJson(recJson, "signals") : new List<string>();
                    if (agentName is not null)
                    {
                        <div class="card recommendation-panel" style="margin-bottom:20px;">
                            <div class="card-header">
                                <span class="card-title">Agent Recommendation</span>
                            </div>
                            <div class="card-body" style="display:flex;flex-direction:column;gap:12px;">
                                <div class="rec-agent-name">@agentName</div>
                                @if (recDomain is not null)
                                {
                                    <div><span class="domain-badge domain-badge-@recDomain.Replace("-", "")">@recDomain</span></div>
                                }
                                @if (recConf.HasValue)
                                {
                                    <div>
                                        <div class="field-key">Confidence</div>
                                        <div class="field-val" style="font-size:13px;">@((recConf.Value * 100).ToString("F0"))%</div>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(reasoning))
                                {
                                    <div>
                                        <div class="field-key">Reasoning</div>
                                        <p class="rec-reasoning">@reasoning</p>
                                    </div>
                                }
                                @if (signalsRaw.Any())
                                {
                                    <div>
                                        <div class="field-key" style="margin-bottom:6px;">Signals</div>
                                        <div class="signal-chips">
                                            @foreach (var sig in signalsRaw)
                                            {
                                                <span class="signal-chip">@sig</span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }

                <!-- Tags -->
                @if (_entry.Output.Tags.Any())
                {
                    <div class="card">
                        <div class="card-header"><span class="card-title">Tags</span></div>
                        <div class="card-body">
                            <div class="tag-list">
                                @foreach (var tag in _entry.Output.Tags)
                                {
                                    <span class="tag">@tag</span>
                                }
                            </div>
                        </div>
                    </div>
                }

                <!-- Metadata -->
                <div class="card" style="margin-top:20px;">
                    <div class="card-header"><span class="card-title">Metadata</span></div>
                    <div class="card-body" style="display:flex;flex-direction:column;gap:14px;">
                        <div>
                            <div class="field-key">Source file</div>
                            <div class="field-val" style="font-size:13px;word-break:break-all;">@m.SourceFile</div>
                        </div>
                        <div>
                            <div class="field-key">Extraction method</div>
                            <div style="margin-top:4px;"><span class="badge method-badge">@m.ExtractionMethod</span></div>
                        </div>
                        <div>
                            <div class="field-key">Domain</div>
                            <div style="margin-top:4px;"><span class="badge domain-badge">@_entry.Output.Categories.Domain</span></div>
                        </div>
                        <div>
                            <div class="field-key">Sensitivity</div>
                            <div style="margin-top:4px;">
                                <span class="badge @_entry.Output.Categories.Sensitivity">
                                    <div class="badge-dot"></div>
                                    @_entry.Output.Categories.Sensitivity
                                </span>
                            </div>
                        </div>
                        @if (m.Language.Any())
                        {
                            <div>
                                <div class="field-key">Languages</div>
                                <div class="field-val" style="font-size:13px;">@string.Join(", ", m.Language).ToUpper()</div>
                            </div>
                        }
                        <div>
                            <div class="field-key">Processed</div>
                            <div class="field-val" style="font-size:13px;">@_entry.ProcessedAt.ToString("d MMM yyyy, HH:mm UTC")</div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <!-- Rating -->
        <div class="rating-bar afu">
            <span class="rating-label">Was this extraction accurate?</span>
            <button class="rating-btn @(_entry.Rating == ExtractionRating.Good ? "rating-good active" : "rating-good")"
                    @onclick='() => { Repo.Rate(_entry.Id, ExtractionRating.Good); StateHasChanged(); }'>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="@(_entry.Rating == ExtractionRating.Good ? "currentColor" : "none")" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
                Good
            </button>
            <button class="rating-btn @(_entry.Rating == ExtractionRating.Bad ? "rating-bad active" : "rating-bad")"
                    @onclick='() => { Repo.Rate(_entry.Id, ExtractionRating.Bad); StateHasChanged(); }'>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="@(_entry.Rating == ExtractionRating.Bad ? "currentColor" : "none")" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3H10z"/><path d="M17 2h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17"/></svg>
                Bad
            </button>
        </div>

    </div>
}

@code {
    [Parameter] public string Id { get; set; } = "";

    ResultsEntry? _entry;
    string _json = "";
    Dictionary<string, bool> _expanded = [];

    bool IsOpen(string key) => _expanded.TryGetValue(key, out var v) && v;
    void Toggle(string key) => _expanded[key] = !IsOpen(key);

    protected override void OnParametersSet()
    {
        _entry = Repo.GetById(Id);
        _expanded = [];
        if (_entry is not null)
        {
            _json = System.Text.Json.JsonSerializer.Serialize(
                _entry.Output,
                new System.Text.Json.JsonSerializerOptions
                {
                    WriteIndented = true,
                    Encoder = System.Text.Encodings.Web.JavaScriptEncoder.UnsafeRelaxedJsonEscaping
                });
        }
    }

    async Task DownloadJson()
    {
        if (_entry is null) return;
        var docType = Sanitize(_entry.Output.Meta.DocumentType);
        await JS.InvokeVoidAsync("triggerDownload", $"{docType}-{_entry.Id}.json", "application/json", _json);
    }

    async Task DownloadCsv()
    {
        if (_entry is null) return;
        var csv = ExportSvc.BuildCsv(_entry.Output);
        var docType = Sanitize(_entry.Output.Meta.DocumentType);
        await JS.InvokeVoidAsync("triggerDownload", $"{docType}-{_entry.Id}.csv", "text/csv", csv);
    }

    static string Sanitize(string name) =>
        string.IsNullOrWhiteSpace(name) ? "result"
            : new string(name.Select(c => char.IsLetterOrDigit(c) ? char.ToLower(c) : '-').ToArray()).Trim('-');

    static Dictionary<string, string> ParseJsonObjectFlat(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return [];
        try
        {
            var obj = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, System.Text.Json.JsonElement>>(json);
            if (obj is null) return [];
            return obj.ToDictionary(kv => kv.Key, kv => kv.Value.ToString());
        }
        catch { return []; }
    }

    static List<string> ParseJsonStringArrayFromJson(string json, string key)
    {
        try
        {
            var obj = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(json);
            if (obj.TryGetProperty(key, out var arr))
                return System.Text.Json.JsonSerializer.Deserialize<List<string>>(arr.GetRawText()) ?? [];
        }
        catch { }
        return [];
    }

    static List<Dictionary<string, string>> ParseJsonArray(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return [];
        try
        {
            var arr = System.Text.Json.JsonSerializer.Deserialize<List<Dictionary<string, System.Text.Json.JsonElement>>>(json);
            if (arr is null) return [];
            return arr.Select(d => d.ToDictionary(kv => kv.Key, kv => kv.Value.ToString())).ToList();
        }
        catch { return []; }
    }

    static List<string> ParseJsonStringArray(object? obj)
    {
        var json = obj?.ToString();
        if (string.IsNullOrWhiteSpace(json)) return [];
        try
        {
            return System.Text.Json.JsonSerializer.Deserialize<List<string>>(json) ?? [];
        }
        catch { return []; }
    }

    static string DomainIconLarge(string domain) => domain switch
    {
        "finance"   => "<svg width='28' height='28' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round'><line x1='12' y1='1' x2='12' y2='23'/><path d='M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6'/></svg>",

@page "/results"
@inject ResultsRepository Repo
@inject NavigationManager Nav

<PageTitle>Results — OmniExtract</PageTitle>

<header class="topbar">
    <span class="topbar-title">Results</span>
    <span class="topbar-sep">/</span>
    <span class="topbar-sub">@_filtered.Count document@(_filtered.Count == 1 ? "" : "s")</span>
    <div class="topbar-right">
        <button class="btn btn-primary btn-sm" @onclick='() => Nav.NavigateTo("/upload")'>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            New Extraction
        </button>
    </div>
</header>

<div class="page-content afu">

    <!-- Filter bar -->
    <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:20px;">

        <!-- Row 1: search + domain chips -->
        <div class="filter-row">
            <div class="search-wrap">
                <svg class="search-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input class="search-inp" type="text" placeholder="Search by name, type, or domain…" @bind="_search" @bind:event="oninput" />
            </div>
            @foreach (var d in _domains)
            {
                <button class="filter-chip @(_activeDomain == d ? "active" : "")" @onclick="() => ToggleDomain(d)">@Capitalize(d)</button>
            }
        </div>

        <!-- Row 2: document type chips -->
        @if (_docTypes.Any())
        {
            <div class="filter-row" style="padding-top:0;border-top:none;">
                <span style="font-size:11px;color:var(--text-400);white-space:nowrap;align-self:center;">Type</span>
                @foreach (var dt in _docTypes)
                {
                    <button class="filter-chip @(_activeDocType == dt ? "active" : "")" @onclick="() => ToggleDocType(dt)">@dt</button>
                }
            </div>
        }

        <!-- Row 3: sensitivity chips -->
        @if (_sensitivities.Any())
        {
            <div class="filter-row" style="padding-top:0;border-top:none;">
                <span style="font-size:11px;color:var(--text-400);white-space:nowrap;align-self:center;">Sensitivity</span>
                @foreach (var s in _sensitivities)
                {
                    <button class="filter-chip @(_activeSensitivity == s ? "active" : "")" @onclick="() => ToggleSensitivity(s)">@Capitalize(s)</button>
                }
            </div>
        }

        <!-- Row 4: date presets + sort + clear -->
        <div class="filter-row" style="padding-top:0;border-top:none;">
            <span style="font-size:11px;color:var(--text-400);white-space:nowrap;align-self:center;">Date</span>
            @foreach (var preset in new[] { "all", "today", "last7", "last30" })
            {
                <button class="filter-chip @(_datePreset == preset ? "active" : "")" @onclick="() => _datePreset = preset">
                    @(preset switch { "all" => "All time", "today" => "Today", "last7" => "Last 7 days", "last30" => "Last 30 days", _ => preset })
                </button>
            }
            <span style="font-size:11px;color:var(--text-400);white-space:nowrap;align-self:center;margin-left:12px;">Sort</span>
            <button class="filter-chip @(_sortBy == "date" ? "active" : "")" @onclick='() => _sortBy = "date"'>Newest</button>
            <button class="filter-chip @(_sortBy == "confidence" ? "active" : "")" @onclick='() => _sortBy = "confidence"'>Confidence ↓</button>
            @if (_anyFilterActive)
            {
                <button class="btn btn-sm btn-ghost" style="margin-left:8px;" @onclick="ClearAllFilters">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Clear filters
                </button>
            }
        </div>
    </div>

    <!-- Accuracy stats -->
    @if (_ratedCount > 0)
    {
        <div class="accuracy-bar afu">
            <span class="accuracy-bar-label">Accuracy</span>
            <span class="accuracy-stat">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="accuracy-good"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/></svg>
                <span class="accuracy-stat-val accuracy-good">@_goodCount</span>
            </span>
            <span class="accuracy-sep">·</span>
            <span class="accuracy-stat">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="accuracy-bad"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3H10z"/></svg>
                <span class="accuracy-stat-val accuracy-bad">@_badCount</span>
            </span>
            <span class="accuracy-sep">·</span>
            <span class="accuracy-pct">@(((double)_goodCount / _ratedCount * 100).ToString("F1"))% accurate</span>
            <span class="accuracy-sep" style="font-size:11px;margin-left:4px;">(@_ratedCount rated)</span>
        </div>
    }

    <!-- Grid -->
    @if (_filtered.Any())
    {
        <div class="result-grid">
            @foreach (var entry in _filtered)
            {
                <div class="result-card afu" @onclick='() => Nav.NavigateTo($"/results/{entry.Id}")' style="position:relative;">
                    <!-- Delete button -->
                    <button class="rc-delete" title="Delete"
                            @onclick="() => DeleteEntry(entry.Id)" @onclick:stopPropagation="true">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3,6 5,6 21,6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                    </button>

                    @if (entry.IsFailed)
                    {
                        <div class="rc-head">
                            <div class="rc-icon">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--error)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                            </div>
                            <div>
                                <div class="rc-name" style="color:var(--error)">Extraction Failed</div>
                                <div class="rc-type">@TruncateName(entry.FileName)</div>
                            </div>
                        </div>
                        <div class="tag-list">
                            @if (entry.ErrorMessage is not null)
                            {
                                <span class="tag" style="color:var(--error);background:rgba(248,113,113,.1);border-color:rgba(248,113,113,.3);max-width:100%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@entry.ErrorMessage</span>
                            }
                        </div>
                        <div class="rc-foot">
                            <div class="badge" style="background:rgba(248,113,113,.15);color:var(--error);border:1px solid rgba(248,113,113,.3);">
                                <div class="badge-dot" style="background:var(--error);"></div>
                                Failed
                            </div>
                            <span style="font-size:11px;color:var(--text-300);">@TimeAgo(entry.ProcessedAt)</span>
                        </div>
                    }
                    else
                    {
                        var conf = entry.Output.Meta.Confidence * 100;
                        <div class="rc-head">
                            <div class="rc-icon">
                                @((MarkupString)DocIcon(entry.Output.Categories.Domain))
                            </div>
                            <div>
                                <div class="rc-name">@entry.Output.Meta.DocumentType</div>
                                <div class="rc-type">@TruncateName(entry.FileName)</div>
                            </div>
                        </div>
                        <div class="tag-list">
                            @foreach (var tag in entry.Output.Tags.Take(4))
                            {
                                <span class="tag">@tag</span>
                            }
                            @if (entry.Output.Tags.Count > 4)
                            {
                                <span class="tag">+@(entry.Output.Tags.Count - 4)</span>
                            }
                        </div>
                        <div class="rc-foot">
                            <div class="badge @entry.Output.Categories.Sensitivity">
                                <div class="badge-dot"></div>
                                @entry.Output.Categories.Sensitivity
                            </div>
                            <div style="display:flex;align-items:center;gap:8px;">
                                <span style="font-size:11px;color:var(--text-300);">@TimeAgo(entry.ProcessedAt)</span>
                                <span class="rc-conf" style="color:@ConfColor(conf)">@conf.ToString("F0")%</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty">
            <div class="empty-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </div>
            <div class="empty-title">No results found</div>
            <div class="empty-sub">Try a different search term or clear the filters.</div>
        </div>
    }

</div>

@code {
    string _search = "";
    string? _activeDomain;
    string? _activeDocType;
    string? _activeSensitivity;
    string _datePreset = "all";
    string _sortBy = "date";

    IReadOnlyList<ResultsEntry> _all = [];
    List<string> _domains = [];
    List<string> _docTypes = [];
    List<string> _sensitivities = [];

    List<ResultsEntry> _filtered
    {
        get
        {
            var q = _all.Where(e =>
                (string.IsNullOrWhiteSpace(_search) ||
                 e.FileName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                 (!e.IsFailed && e.Output.Meta.DocumentType.Contains(_search, StringComparison.OrdinalIgnoreCase)) ||
                 (!e.IsFailed && e.Output.Categories.Domain.Contains(_search, StringComparison.OrdinalIgnoreCase)) ||
                 (!e.IsFailed && e.Output.Tags.Any(t => t.Contains(_search, StringComparison.OrdinalIgnoreCase))))
                && (_activeDomain == null || (!e.IsFailed && e.Output.Categories.Domain == _activeDomain))
                && (_activeDocType == null || (!e.IsFailed && e.Output.Meta.DocumentType == _activeDocType))
                && (_activeSensitivity == null || (!e.IsFailed && e.Output.Categories.Sensitivity == _activeSensitivity))
                && MatchesDatePreset(e.ProcessedAt));

            return _sortBy == "confidence"
                ? q.OrderByDescending(e => e.Output.Meta.Confidence).ToList()
                : q.OrderByDescending(e => e.ProcessedAt).ToList();
        }
    }

    bool _anyFilterActive =>
        _activeDomain != null || _activeDocType != null || _activeSensitivity != null || _datePreset != "all";

    int _goodCount => _all.Count(e => e.Rating == ExtractionRating.Good);
    int _badCount  => _all.Count(e => e.Rating == ExtractionRating.Bad);
    int _ratedCount => _goodCount + _badCount;

    protected override void OnInitialized() => Refresh();

    void Refresh()
    {
        _all = Repo.GetAll();
        var nonFailed = _all.Where(e => !e.IsFailed).ToList();
        _domains = nonFailed.Select(e => e.Output.Categories.Domain).Distinct().OrderBy(d => d).ToList();
        _docTypes = nonFailed.Select(e => e.Output.Meta.DocumentType).Where(t => !string.IsNullOrWhiteSpace(t)).Distinct().OrderBy(t => t).ToList();
        _sensitivities = nonFailed.Select(e => e.Output.Categories.Sensitivity).Where(s => !string.IsNullOrWhiteSpace(s)).Distinct().OrderBy(s => s).ToList();
    }

    void DeleteEntry(string id)
    {
        Repo.Delete(id);
        Refresh();
    }

    bool MatchesDatePreset(DateTime processedAt)
    {
        var today = DateTime.UtcNow.Date;
        return _datePreset switch
        {
            "today"  => processedAt.Date == today,
            "last7"  => processedAt >= today.AddDays(-6),
            "last30" => processedAt >= today.AddDays(-29),
            _        => true
        };
    }

    void ToggleDomain(string d)      => _activeDomain      = _activeDomain      == d ? null : d;
    void ToggleDocType(string dt)    => _activeDocType     = _activeDocType     == dt ? null : dt;
    void ToggleSensitivity(string s) => _activeSensitivity = _activeSensitivity == s ? null : s;

    void ClearAllFilters()
    {
        _activeDomain      = null;
        _activeDocType     = null;
        _activeSensitivity = null;
        _datePreset        = "all";
    }

    static string Capitalize(string s) =>
        string.IsNullOrEmpty(s) ? s : char.ToUpper(s[0]) + s[1..];

    static string TruncateName(string s) =>
        s.Length > 40 ? s[..38] + "…" : s;

    static string TimeAgo(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        if (diff.TotalMinutes < 2)  return "just now";
        if (diff.TotalHours < 1)    return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalDays < 1)     return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7)     return $"{(int)diff.TotalDays}d ago";
        return dt.ToString("d MMM");
    }

    static string ConfColor(double pct) => pct >= 90 ? "var(--success)" : pct >= 75 ? "var(--warning)" : "var(--error)";

    static string DocIcon(string domain) => domain switch
    {
        "finance"   => "<svg width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round'><line x1='12' y1='1' x2='12' y2='23'/><path d='M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6'/></svg>",
        "hr"        => "<svg width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round'><path d='M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2'/><circle cx='12' cy='7' r='4'/></svg>",
        "legal"     => "<svg width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round'><path d='M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z'/></svg>",
        "technical" => "<svg width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round'><rect x='2' y='3' width='20' height='14' rx='2'/><line x1='8' y1='21' x2='16' y2='21'/><line x1='12' y1='17' x2='12' y2='21'/></svg>",
        _           => "<svg width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round'><path d='M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z'/><polyline points='14,2 14,8 20,8'/></svg>",
    };
}

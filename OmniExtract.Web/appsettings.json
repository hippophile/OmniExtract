{
  "OpenAI": {
    "Endpoint": "https://models.inference.ai.azure.com",
    "Model": "gpt-4.1",
    "VisionModel": "gpt-4.1",
  },
  "Processing": {
    "ApiConcurrency": 2,
    "VisionChunkSize": 6,
    "VisionMaxDimension": 1024,
    "PdfDpi": 300,
    "MaxOutputTokens": 4096,
    "ModelContextLimit": 128000,
    "TokenBuffer": 8000,
    "HeuristicFallbackThreshold": 3
  },
  "Paths": {
    "WatchDir": "./inbox"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}

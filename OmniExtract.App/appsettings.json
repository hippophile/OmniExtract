{
  "OpenAI": {
    "Endpoint": "https://models.inference.ai.azure.com",
    "Model": "gpt-4.1",
    "VisionModel": "gpt-4o",
    "ApiKeyEnvVar": "GITHUB_TOKEN"
  },
  "Processing": {
    "ApiConcurrency": 2,
    "VisionChunkSize": 6,
    "VisionMaxDimension": 1024,
    "PdfDpi": 150,
    "MaxOutputTokens": 4096,
    "ModelContextLimit": 40000,
    "TokenBuffer": 8000
  },
  "Paths": {
    "WatchDir": "./inbox"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  }
}
